---
import collectionData from '../data/collections.json';
import type { CollectionManifest } from '../lib/collection-views';

interface Props {
  current?: string;
}

const { current = 'home' } = Astro.props;
const items = (collectionData as CollectionManifest).navigation;
---

<nav class="taxonomy" aria-label="공개 컬렉션">
  <ul>
    {items.map((item) => (
      <li>
        <a
          class:list={['taxonomy-item', { 'is-current': current === item.id }]}
          href={item.href}
          aria-current={current === item.id ? 'page' : undefined}
        >
          {item.label}
        </a>
      </li>
    ))}
  </ul>
</nav>
