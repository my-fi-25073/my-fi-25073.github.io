---
import { getCollection } from 'astro:content';
import ArchiveSearch from '../../components/ArchiveSearch.astro';
import CollectionFilter from '../../components/CollectionFilter.astro';
import GalleryCard from '../../components/GalleryCard.astro';
import TaxonomyNav from '../../components/TaxonomyNav.astro';
import collectionData from '../../data/collections.json';
import SiteLayout from '../../layouts/SiteLayout.astro';
import {
  groupIdsForRecord,
  groupsWithCounts,
  recordsForCollectionView,
  type CollectionManifest,
} from '../../lib/collection-views';

const manifest = collectionData as CollectionManifest;
const entries = await getCollection('gallery');
const entryBySlug = new Map(entries.map((entry) => [entry.data.slug, entry]));
const records = recordsForCollectionView(
  entries.map((entry) => entry.data),
  manifest,
  'keycap-collections',
);
const groups = groupsWithCounts(records, manifest, ['keycap-collections']);
const defaultGroup = groups[0]?.id;
if (!defaultGroup) throw new Error('Keycap Collection View has no visible groups.');
---

<SiteLayout title="키캡 아카이브">
  <section class="archive-intro shell" aria-labelledby="keycap-title">
    <p class="eyebrow">Keycap</p>
    <h1 id="keycap-title">키캡</h1>
    <p class="archive-description">
      보유한 키캡 시리즈를 제조사, 프로파일, 계열별로 정리했습니다.
    </p>
  </section>

  <div class="shell archive-controls">
    <TaxonomyNav current="keycaps" />
    <p class="archive-count">{groups.length} collections · {records.length} series</p>
  </div>

  <CollectionFilter groups={groups} defaultGroup={defaultGroup} label="키캡 분류" />
  <ArchiveSearch />

  <section class="gallery-grid shell" aria-label="키캡 컬렉션">
    {records.map((gallery, index) => {
      const entry = entryBySlug.get(gallery.slug);
      if (!entry) throw new Error(`Keycap entry is missing: ${gallery.slug}`);
      return (
        <GalleryCard
          gallery={entry.data}
          index={index}
          groups={groupIdsForRecord(gallery, manifest, ['keycap-collections'])}
        />
      );
    })}
  </section>
</SiteLayout>
