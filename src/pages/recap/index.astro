---
import { getCollection } from 'astro:content';
import TaxonomyNav from '../../components/TaxonomyNav.astro';
import collectionData from '../../data/collections.json';
import SiteLayout from '../../layouts/SiteLayout.astro';
import {
  recordsForCollectionView,
  type CollectionManifest,
} from '../../lib/collection-views';

const manifest = collectionData as CollectionManifest;
const keyboards = (await getCollection('keyboards')).map((entry) => entry.data);
const recaps = [2025, 2024].map((year) => {
  const records = recordsForCollectionView(keyboards, manifest, `recap-${year}-gallery`);
  const months = new Set(records.map((record) => record.lastBuiltAt?.slice(0, 7))).size;
  return { year, count: records.length, months };
});
---

<SiteLayout title="Recap">
  <section class="archive-intro shell" aria-labelledby="recap-title">
    <p class="eyebrow">My-Fi Recap</p>
    <h1 id="recap-title">연도별 리캡</h1>
    <p class="archive-description">
      완성한 키보드를 연도와 월별로 모았습니다.
    </p>
  </section>

  <div class="shell archive-controls">
    <TaxonomyNav current="recap" />
    <p class="archive-count">{recaps.length} yearly recaps</p>
  </div>

  <section class="recap-index shell" aria-label="연도별 Recap">
    {recaps.map((recap) => (
      <a href={`/recap/${recap.year}/`} class="recap-year-card">
        <span>{recap.year}</span>
        <div>
          <h2>{recap.count} builds</h2>
          <p>기록이 있는 달 {recap.months}개월 · 월별 갤러리 · 구매처</p>
        </div>
        <strong aria-hidden="true">→</strong>
      </a>
    ))}
  </section>

  <section class="recap-log-callout shell" aria-labelledby="practice-log-title">
    <p class="eyebrow">Activity</p>
    <h2 id="practice-log-title">작업 기록</h2>
    <p>제작, 장착, 정비 기록은 날짜순으로 따로 모았습니다.</p>
    <a href="/activity/">활동 기록 보기 →</a>
  </section>
</SiteLayout>
