---
import { getCollection } from 'astro:content';
import ArchiveView from '../components/ArchiveView.astro';
import SiteLayout from '../layouts/SiteLayout.astro';

const [keycaps, keyboards, domainRecords] = await Promise.all([
  getCollection('gallery'),
  getCollection('keyboards'),
  getCollection('records'),
]);
---

<SiteLayout>
  <ArchiveView
    current="all"
    keycaps={keycaps}
    keyboards={keyboards}
    domainRecords={domainRecords}
  />
</SiteLayout>
