---
import type { CollectionEntry } from 'astro:content';
import collectionData from '../data/collections.json';
import {
  groupIdsForRecord,
  groupsWithCounts,
  recordsForCollectionView,
  type CollectionManifest,
} from '../lib/collection-views';
import ArchiveSearch from './ArchiveSearch.astro';
import CollectionFilter from './CollectionFilter.astro';
import DomainRecordCard from './DomainRecordCard.astro';
import TaxonomyNav from './TaxonomyNav.astro';

interface Props {
  records: CollectionEntry<'records'>[];
}

type DomainEntry = CollectionEntry<'records'>;
type SwitchFamilyData = Extract<DomainEntry['data'], { kind: 'switch-family' }>;

const { records } = Astro.props;
const manifest = collectionData as CollectionManifest;
const families = records
  .map((entry) => entry.data)
  .filter((record): record is SwitchFamilyData => record.kind === 'switch-family');
const switches = recordsForCollectionView(families, manifest, 'switch-manufacturers');
const frankenRecipes = recordsForCollectionView(families, manifest, 'switch-franken');
const allGroups = groupsWithCounts(switches, manifest, ['switch-manufacturers']);
const groups = allGroups.map((group) => ({
  ...group,
  label: group.id.startsWith('rating-')
    ? `Rating · ${group.label}`
    : `Maker · ${group.label}`,
}));
const defaultGroup = groups.find((group) => group.id === 'cherry')?.id ?? groups[0]?.id;
if (!defaultGroup) throw new Error('Switch Collection View has no visible groups.');
---

<section class="archive-intro shell" aria-labelledby="switch-title">
  <p class="eyebrow">Switch</p>
  <h1 id="switch-title">스위치</h1>
  <p class="archive-description">
    스위치 패밀리를 제조사와 평점별로 정리했습니다. 직접 조합한 스위치는 Franken Recipes에 따로 모았습니다.
  </p>
</section>

<div class="shell archive-controls">
  <TaxonomyNav current="switches" />
  <p class="archive-count">{switches.length} families · {frankenRecipes.length} Franken</p>
</div>

<CollectionFilter groups={groups} defaultGroup={defaultGroup} label="스위치 분류" />
<ArchiveSearch />

<div class="archive-sections">
  <section class="archive-section shell" aria-labelledby="switch-collection-heading" data-archive-group>
    <div class="section-heading">
      <h2 id="switch-collection-heading">Switch Families</h2>
      <p>Maker / Rating</p>
    </div>
    <div class="gallery-grid archive-section-grid" aria-label="스위치 Family 목록">
      {switches.map((record, index) => (
        <DomainRecordCard
          record={record}
          index={index}
          headingLevel={3}
          groups={groupIdsForRecord(record, manifest, ['switch-manufacturers'])}
        />
      ))}
    </div>
  </section>

  {frankenRecipes.length > 0 && (
    <section class="archive-section shell" aria-labelledby="franken-collection-heading" data-archive-group>
      <div class="section-heading">
        <h2 id="franken-collection-heading">Franken Recipes</h2>
        <p>{frankenRecipes.length} recipes</p>
      </div>
      <div class="gallery-grid archive-section-grid" aria-label="프랑켄 스위치 레시피 목록">
        {frankenRecipes.map((record, index) => (
          <DomainRecordCard
            record={record}
            index={index}
            headingLevel={3}
            filterStatic
          />
        ))}
      </div>
    </section>
  )}
</div>
