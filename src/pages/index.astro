---
import { getCollection } from 'astro:content';
import KeyboardCard from '../components/KeyboardCard.astro';
import TaxonomyNav from '../components/TaxonomyNav.astro';
import collectionData from '../data/collections.json';
import SiteLayout from '../layouts/SiteLayout.astro';
import {
  recordsForCollectionView,
  requiredCollectionView,
  type CollectionManifest,
} from '../lib/collection-views';

const manifest = collectionData as CollectionManifest;
const [keyboardEntries, keycapEntries, domainEntries] = await Promise.all([
  getCollection('keyboards'),
  getCollection('gallery'),
  getCollection('records'),
]);
const keyboards = keyboardEntries.map((entry) => entry.data);
const entryBySlug = new Map(keyboardEntries.map((entry) => [entry.data.slug, entry]));
const homeView = requiredCollectionView(manifest, 'home-latest').view;
const recentLimit = typeof homeView.projection.limit === 'number' ? homeView.projection.limit : 6;
const recent = recordsForCollectionView(keyboards, manifest, 'home-latest').slice(0, recentLimit);
const completed = recordsForCollectionView(keyboards, manifest, 'keyboard-all');
const keycaps = recordsForCollectionView(
  keycapEntries.map((entry) => entry.data),
  manifest,
  'keycap-collections',
);
const switchFamilies = domainEntries
  .map((entry) => entry.data)
  .filter((record) => record.kind === 'switch-family');
const switches = recordsForCollectionView(switchFamilies, manifest, 'switch-manufacturers');
const recapYears = [2025, 2024].map((year) => ({
  year,
  count: recordsForCollectionView(keyboards, manifest, `recap-${year}-gallery`).length,
}));
const portals = [
  { label: 'Keyboard', href: '/keyboards/', count: completed.length, note: '완성한 빌드' },
  { label: 'Keycap', href: '/keycaps/', count: keycaps.length, note: '키캡 시리즈' },
  { label: 'Switch', href: '/switches/', count: switches.length, note: '스위치 패밀리' },
  { label: 'Recap', href: '/recap/', count: recapYears.length, note: '연도별 기록' },
];
---

<SiteLayout>
  <section class="archive-intro home-intro shell" aria-labelledby="home-title">
    <p class="eyebrow">My-Fi Keyboard</p>
    <h1 id="home-title">키보드 기록</h1>
    <p class="archive-description">
      완성한 키보드와 보유한 키캡·스위치, 연도별 빌드 기록을 모았습니다.
    </p>
  </section>

  <div class="shell archive-controls">
    <TaxonomyNav current="home" />
    <p class="archive-count">2024—</p>
  </div>

  <section class="collection-portals shell" aria-label="주요 컬렉션">
    {portals.map((portal, index) => (
      <a href={portal.href} class="collection-portal">
        <span>{String(index + 1).padStart(2, '0')}</span>
        <div>
          <h2>{portal.label}</h2>
          <p>{portal.note}</p>
        </div>
        <strong>{portal.count}</strong>
      </a>
    ))}
  </section>

  <section class="home-section shell" aria-labelledby="recent-builds-title">
    <div class="section-heading">
      <h2 id="recent-builds-title">Recent Builds</h2>
      <a href="/keyboards/">키보드 전체 보기 →</a>
    </div>
    <div class="gallery-grid home-grid">
      {recent.map((keyboard, index) => {
        const entry = entryBySlug.get(keyboard.slug);
        if (!entry) throw new Error(`Keyboard entry is missing: ${keyboard.slug}`);
        return <KeyboardCard keyboard={entry.data} index={index} headingLevel={3} />;
      })}
    </div>
  </section>

  <section class="home-section shell" aria-labelledby="recap-home-title">
    <div class="section-heading">
      <h2 id="recap-home-title">Recap</h2>
      <a href="/recap/">연도별 보기 →</a>
    </div>
    <div class="recap-portals">
      {recapYears.map((recap) => (
        <a href={`/recap/${recap.year}/`}>
          <span>{recap.year}</span>
          <strong>{recap.count} builds</strong>
          <small>월별 갤러리 · 빌드 수 · 구매처</small>
        </a>
      ))}
    </div>
  </section>
</SiteLayout>
