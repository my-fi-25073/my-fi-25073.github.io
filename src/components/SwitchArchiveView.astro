---
import type { CollectionEntry } from 'astro:content';
import ArchiveSearch from './ArchiveSearch.astro';
import DomainRecordCard from './DomainRecordCard.astro';
import TaxonomyNav from './TaxonomyNav.astro';

interface Props {
  records: CollectionEntry<'records'>[];
}

type DomainEntry = CollectionEntry<'records'>;
type SwitchFamilyData = Extract<DomainEntry['data'], { kind: 'switch-family' }>;
type SwitchFamilyEntry = Omit<DomainEntry, 'data'> & { data: SwitchFamilyData };

function isSwitchFamily(entry: DomainEntry): entry is SwitchFamilyEntry {
  return entry.data.kind === 'switch-family';
}

const { records } = Astro.props;
const families = records
  .filter(isSwitchFamily)
  .toSorted((a, b) => a.data.title.localeCompare(b.data.title, 'ko'));
const switches = families.filter((entry) => (
  entry.data.familyKind !== 'franken' && entry.data.variants.length > 0
));
const frankenRecipes = families.filter((entry) => entry.data.familyKind === 'franken');
const countLabel = `${switches.length} switches · ${frankenRecipes.length} Franken`;
---

<section class="archive-intro shell" aria-labelledby="archive-title">
  <p class="eyebrow">Keyboard practice, 2024—</p>
  <h1 id="archive-title">만들고, 바꾸고,<br />오래 기록하는 키보드.</h1>
  <p class="archive-description">
    기성 스위치와 직접 조합한 프랑켄 레시피를 구분해 기록합니다.
  </p>
</section>

<div class="shell archive-controls">
  <TaxonomyNav current="switches" />
  <p class="archive-count">{countLabel}</p>
</div>

<ArchiveSearch />

<div class="archive-sections">
  {switches.length > 0 && (
    <section class="archive-section shell" aria-labelledby="switch-collection-heading" data-archive-group>
      <div class="section-heading">
        <h2 id="switch-collection-heading">Switches</h2>
        <p>{switches.length} families</p>
      </div>
      <div class="gallery-grid archive-section-grid" aria-label="일반 스위치 목록">
        {switches.map((record, index) => (
          <DomainRecordCard record={record.data} index={index} headingLevel={3} />
        ))}
      </div>
    </section>
  )}

  {frankenRecipes.length > 0 && (
    <section class="archive-section shell" aria-labelledby="franken-collection-heading" data-archive-group>
      <div class="section-heading">
        <h2 id="franken-collection-heading">Franken Recipes</h2>
        <p>{frankenRecipes.length} recipes</p>
      </div>
      <div class="gallery-grid archive-section-grid" aria-label="프랑켄 스위치 레시피 목록">
        {frankenRecipes.map((record, index) => (
          <DomainRecordCard record={record.data} index={index} headingLevel={3} />
        ))}
      </div>
    </section>
  )}
</div>
