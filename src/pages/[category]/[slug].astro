---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import DisplayFields from '../../components/DisplayFields.astro';
import Lightbox from '../../components/Lightbox.astro';
import SiteLayout from '../../layouts/SiteLayout.astro';
import {
  buildDomainFields,
  domainLabels,
  domainSummary,
} from '../../lib/domain-display';

export async function getStaticPaths() {
  const records = await getCollection('records');
  return records.map((entry) => ({
    params: { category: entry.data.category, slug: entry.data.slug },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'records'>;
}

const { entry } = Astro.props;
const record = entry.data;
const labels = domainLabels(record);
const fields = buildDomainFields(record);
const summary = domainSummary(record);
const partLabels = {
  stem: 'Stem',
  bottom_housing: 'Bottom housing',
  top_housing: 'Top housing',
};
const springResolutionLabels = {
  inherit: '기준 구성 상속',
  selected: '선택됨',
  stock_unresolved: '순정 스프링 미해결',
  unknown: '알 수 없음',
};
---

<SiteLayout title={record.title} description={`${record.title} ${labels.korean} 기록`}>
  <article class="detail shell">
    <a class="back-link" href={`/${record.category}/`}>← {labels.archive}</a>
    <header class="detail-header">
      <p class="eyebrow">{labels.singular} record</p>
      <h1>{record.title}</h1>
      <p class="detail-summary">{summary}</p>
    </header>

    <section class="series-properties" aria-labelledby="domain-properties-heading">
      <div class="section-heading">
        <h2 id="domain-properties-heading">Details</h2>
      </div>
      <DisplayFields fields={fields} variant="detail" />
    </section>

    {record.kind === 'switch-family' && record.variants.length > 0 && (
      <section class="record-section switch-variants" aria-labelledby="switch-variants-heading">
        <div class="section-heading">
          <h2 id="switch-variants-heading">Variants</h2>
          <p>{record.variants.length} configurations</p>
        </div>
        <div class="switch-variant-grid">
          {record.variants.map((variant) => (
            <article>
              <header>
                <h3>{variant.label}</h3>
                {variant.reference && <span>Reference</span>}
              </header>
              <dl>
                {variant.manufacturer && <><dt>제조사</dt><dd>{variant.manufacturer}</dd></>}
                {variant.switchTypes.length > 0 && <><dt>타입</dt><dd>{variant.switchTypes.join(' · ')}</dd></>}
                {variant.footprintType && <><dt>풋프린트</dt><dd>{variant.footprintType}</dd></>}
                {variant.rating !== null && <><dt>평가</dt><dd>{variant.rating}/5</dd></>}
                <dt>스프링</dt>
                <dd>{variant.spring.name ?? springResolutionLabels[variant.spring.resolution]}</dd>
                <dt>하우징 처리</dt>
                <dd>{variant.housingFit.state === 'applied'
                  ? [variant.housingFit.method, variant.housingFit.material].filter(Boolean).join(' · ')
                  : variant.housingFit.state}</dd>
              </dl>
            </article>
          ))}
        </div>
      </section>
    )}

    {record.kind === 'switch-family' && record.parts.length > 0 && (
      <section class="record-section switch-parts" aria-labelledby="switch-parts-heading">
        <div class="section-heading">
          <h2 id="switch-parts-heading">Franken Recipe</h2>
        </div>
        <ul>
          {record.parts.map((part) => (
            <li><span>{partLabels[part.role]}</span><strong>{part.donor}</strong></li>
          ))}
        </ul>
      </section>
    )}

    {record.kind === 'vendor' && record.links.length > 0 && (
      <section class="record-section vendor-links" aria-labelledby="vendor-links-heading">
        <div class="section-heading">
          <h2 id="vendor-links-heading">Links</h2>
        </div>
        <ul>
          {record.links.map((link) => (
            <li><a href={link.url} target="_blank" rel="noreferrer">{link.label} ↗</a></li>
          ))}
        </ul>
      </section>
    )}

    {record.images.length > 0 && (
      <section class="record-section" aria-labelledby="domain-images-heading">
        <div class="section-heading">
          <h2 id="domain-images-heading">Images</h2>
          <p>{record.images.length} published</p>
        </div>
        <div class="detail-images domain-images">
          {record.images.map((item, index) => {
            const variants = item.variants.toSorted((a, b) => a.width - b.width);
            const display = variants[0];
            const full = variants.at(-1) ?? display;
            const srcset = variants.map((variant) => `${variant.src} ${variant.width}w`).join(', ');
            return (
              <figure>
                <button
                  class="detail-image-button"
                  type="button"
                  data-lightbox-open
                  data-full={full.src}
                  data-alt={item.alt}
                  data-caption={`${record.title} · ${index + 1}`}
                  aria-label={`${index + 1}번째 이미지 확대`}
                >
                  <img
                    src={display.src}
                    srcset={srcset}
                    sizes="(min-width: 960px) 50vw, 100vw"
                    width={display.width}
                    height={display.height}
                    alt={item.alt}
                    loading={index === 0 ? 'eager' : 'lazy'}
                    decoding="async"
                  />
                </button>
              </figure>
            );
          })}
        </div>
      </section>
    )}
  </article>
  <Lightbox />
</SiteLayout>
