---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import DisplayFields from '../../components/DisplayFields.astro';
import Lightbox from '../../components/Lightbox.astro';
import SiteLayout from '../../layouts/SiteLayout.astro';
import { buildKeyboardDetailFields } from '../../lib/keyboard-display';

export async function getStaticPaths() {
  const keyboards = await getCollection('keyboards');
  return keyboards.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'keyboards'>;
}

const { entry } = Astro.props;
const keyboard = entry.data;
const fields = buildKeyboardDetailFields(keyboard);
const summary = '현재 빌드 구성과 사용 기록입니다.';
---

<SiteLayout title={keyboard.title} description={`${keyboard.title} 키보드 기록`}>
  <article class="detail shell">
    <a class="back-link" href="/keyboards/">← Keyboard</a>
    <header class="detail-header">
      <p class="eyebrow">Keyboard</p>
      <h1>{keyboard.title}</h1>
      <p class="detail-summary">{summary}</p>
    </header>

    <section class="series-properties" aria-labelledby="keyboard-properties-heading">
      <div class="section-heading">
        <h2 id="keyboard-properties-heading">빌드 정보</h2>
      </div>
      <DisplayFields fields={fields} variant="detail" />
    </section>

    {keyboard.build.keycaps.length > 0 && (
      <section class="record-section build-keycaps" aria-labelledby="keyboard-keycaps-heading">
        <div class="section-heading">
          <h2 id="keyboard-keycaps-heading">현재 키캡</h2>
          <p>{keyboard.build.keycaps.length}개</p>
        </div>
        <ul>
          {keyboard.build.keycaps.map((keycap) => (
            <li>
              <span>{keycap.kind === 'series' ? 'Series' : 'Kit'}</span>
              <strong><a href={keycap.href}>{keycap.title}</a></strong>
              {keycap.quantity !== null && <small>{keycap.quantity}개</small>}
            </li>
          ))}
        </ul>
      </section>
    )}

    {keyboard.build.switches.length > 0 && (
      <section class="record-section build-keycaps" aria-labelledby="keyboard-switches-heading">
        <div class="section-heading">
          <h2 id="keyboard-switches-heading">현재 스위치</h2>
          <p>{keyboard.build.switches.length}개</p>
        </div>
        <ul>
          {keyboard.build.switches.map((item) => (
            <li>
              <span>Switch Family</span>
              <strong><a href={item.href}>{item.title}</a></strong>
            </li>
          ))}
        </ul>
      </section>
    )}

    {keyboard.build.vendors.length > 0 && (
      <section class="record-section build-keycaps" aria-labelledby="keyboard-vendors-heading">
        <div class="section-heading">
          <h2 id="keyboard-vendors-heading">Vendors</h2>
          <p>{keyboard.build.vendors.length}개</p>
        </div>
        <ul>
          {keyboard.build.vendors.map((item) => (
            <li>
              <span>Vendor</span>
              <strong><a href={item.href}>{item.title}</a></strong>
            </li>
          ))}
        </ul>
      </section>
    )}

    <section class="record-section" aria-labelledby="keyboard-images-heading">
      <div class="section-heading">
        <h2 id="keyboard-images-heading">사진</h2>
        <p>{keyboard.images.length}장</p>
      </div>
      <div class="detail-images keyboard-images">
        {keyboard.images.map((item, index) => {
          const variants = item.variants.toSorted((a, b) => a.width - b.width);
          const display = variants[0];
          const full = variants.at(-1) ?? display;
          const srcset = variants.map((variant) => `${variant.src} ${variant.width}w`).join(', ');
          return (
            <figure>
              <button
                class="detail-image-button"
                type="button"
                data-lightbox-open
                data-full={full.src}
                data-alt={item.alt}
                data-caption={`${keyboard.title} · ${index + 1}`}
                aria-label={`${index + 1}번째 이미지 확대`}
              >
                <img
                  src={display.src}
                  srcset={srcset}
                  sizes="(min-width: 960px) 88vw, 100vw"
                  width={display.width}
                  height={display.height}
                  alt={item.alt}
                  loading={index === 0 ? 'eager' : 'lazy'}
                  decoding="async"
                />
              </button>
            </figure>
          );
        })}
      </div>
    </section>
  </article>
  <Lightbox />
</SiteLayout>
