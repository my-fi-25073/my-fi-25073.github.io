---
import { getCollection } from 'astro:content';
import ArchiveView from '../../components/ArchiveView.astro';
import SiteLayout from '../../layouts/SiteLayout.astro';
import SwitchArchiveView from '../../components/SwitchArchiveView.astro';

export async function getStaticPaths() {
  const categories = [
    ['switches', '스위치 아카이브'],
    ['springs', '스프링 아카이브'],
    ['lubricants', '윤활제 아카이브'],
    ['vendors', '벤더 아카이브'],
  ] as const;
  return categories.map(([category, title]) => ({
    params: { category },
    props: { category, title },
  }));
}

type DomainCategory = 'switches' | 'springs' | 'lubricants' | 'vendors';

interface Props {
  category: DomainCategory;
  title: string;
}

const { category, title } = Astro.props;
const domainRecords = await getCollection('records', (entry) => entry.data.category === category);
---

<SiteLayout title={title}>
  {category === 'switches' ? (
    <SwitchArchiveView records={domainRecords} />
  ) : (
    <ArchiveView
      current={category}
      keycaps={[]}
      keyboards={[]}
      domainRecords={domainRecords}
    />
  )}
</SiteLayout>
